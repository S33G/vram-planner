{
  "$schema": "Curated allow-list of Hugging Face repos to mirror into the model picker.",
  "$notes": [
    "Each entry produces one or more ModelPreset rows in lib/models.generated.json.",
    "The base entry is fetched from HF and uses the model's native dtype.",
    "Optional `quantizations` synthesizes additional rows by re-pricing weights.",
    "Curated entries in lib/models.curated.ts win on id collisions.",
    "Repos marked gated on HF (Llama, Gemma, etc.) require HF_TOKEN to fetch config.json; without a token the script logs a warning and skips them.",
    "Keep this list short and well-known — quality over quantity."
  ],
  "families": [
    {
      "family": "Qwen",
      "repos": [
        "Qwen/Qwen2.5-72B-Instruct",
        "Qwen/Qwen2.5-32B-Instruct",
        "Qwen/Qwen2.5-14B-Instruct",
        "Qwen/Qwen2.5-7B-Instruct",
        "Qwen/Qwen2.5-Coder-32B-Instruct",
        "Qwen/Qwen2.5-Coder-7B-Instruct"
      ],
      "quantizations": ["bf16", "fp8", "int4"]
    },
    {
      "family": "Llama",
      "repos": [
        "meta-llama/Llama-3.3-70B-Instruct",
        "meta-llama/Llama-3.1-70B-Instruct",
        "meta-llama/Llama-3.1-8B-Instruct",
        "meta-llama/Llama-3.2-3B-Instruct",
        "meta-llama/Llama-3.2-1B-Instruct"
      ],
      "quantizations": ["bf16", "fp8", "int4"]
    },
    {
      "family": "Mistral",
